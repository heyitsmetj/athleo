<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/surface_container"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <!-- Primary border indicator -->
    <View
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="#22C55E" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:layout_marginStart="4dp">

        <LinearLayout
            android:id="@+id/topMetaLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HQ BULLETIN"
                android:textColor="#22C55E"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:textAllCaps="true" />
                
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvAnnounceDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAnnounceTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Announcement Title"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topMetaLayout" />

        <TextView
            android:id="@+id/tvAnnounceMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="This is the announcement content..."
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAnnounceTitle" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAnnounceMessage">
            
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/secondary" />
                
            <TextView
                android:id="@+id/tvAnnounceAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="By: Admin"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
